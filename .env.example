# KHUx Server — Environment Configuration
# Copy to .env and adjust for your setup.

# Path to KHUx data directory (misc.mp4, m/, R/ etc.)
KHUX_DATA_DIR=/path/to/khux/data

# Path to repo root (for serving generated misc.png BGI)
KHUX_REPO_DIR=/path/to/KHUx

# Server port
KHUX_PORT=80

# Local IP the game should connect to (DNS redirect target)
KHUX_SERVER_IP=192.168.1.100

# DNS proxy settings
KHUX_DNS_LISTEN_IP=0.0.0.0
KHUX_DNS_PORT=15353
KHUX_DNS_UPSTREAM=8.8.8.8
KHUX_DNS_DOMAIN=api.sp.kingdomhearts.com
